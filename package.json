{
	"name": "@turystack/nestjs-server",
	"private": false,
	"version": "0.0.3",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
		"test": "vitest run",
		"test:cov": "vitest run --coverage",
		"lint": "biome lint ./src",
		"format": "biome format --write ./src",
		"check": "biome check --write ./src"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/turystack/nestjs-server.git"
	},
	"peerDependencies": {
		"@nestjs/common": "^11.0.0",
		"@nestjs/core": "^11.0.0",
		"@nestjs/swagger": "^11.0.0",
		"@scalar/nestjs-api-reference": "^1.0.0",
		"express": "^5.0.0",
		"nestjs-zod": "^5.0.0",
		"reflect-metadata": "^0.2.0",
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.2",
		"@nestjs/common": "^11.0.0",
		"@nestjs/core": "^11.0.0",
		"@nestjs/swagger": "^11.0.0",
		"@scalar/nestjs-api-reference": "^1.0.29",
		"@types/express": "^5.0.6",
		"@vitest/coverage-v8": "^2.1.0",
		"express": "^5.2.1",
		"nestjs-zod": "^5.0.0",
		"reflect-metadata": "^0.2.2",
		"tsc-alias": "^1.8.16",
		"typescript": "^5.5.0",
		"vitest": "^2.1.0",
		"zod": "^4.0.0"
	}
}
